{
  "name": "leadgen-fullstack",
  "private": true,
  "version": "1.0.0",
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": ".\\.venv\\Scripts\\python.exe -m uvicorn backend.app:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "start": ".\\.venv\\Scripts\\python.exe -m uvicorn backend.app:app --host 0.0.0.0 --port 8000",
    "start:multi": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start_backend_multiworker.ps1",
    "start:scale-sim": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start_horizontal_sim.ps1",
    "stop:scale-sim": "powershell -ExecutionPolicy Bypass -File .\\scripts\\stop_horizontal_sim.ps1"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
