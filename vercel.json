{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "installCommand": "npm --prefix frontend install",
    "buildCommand": "npm --prefix frontend run build",
    "outputDirectory": "frontend/dist",
    "functions": {
        "api/[...path].js": {
            "maxDuration": 30
        }
    },
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/[...path].js" },
        { "src": "/(.*)", "dest": "/index.html" }
    ]
}
